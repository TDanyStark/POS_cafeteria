APP_ENV=development
APP_SECRET=change_me_in_production

DB_HOST=localhost
DB_PORT=3306
DB_NAME=pos_cafeteria
DB_USER=root
DB_PASS=

JWT_SECRET=change_me_jwt_secret
JWT_EXPIRATION=3600

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=POS Cafetería
SMTP_FROM_EMAIL=

# Comma-separated list of allowed frontend origins for CORS in production.
# Example: https://pos-cafeteria.com,https://www.pos-cafeteria.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cash register scope: 'personal' (one per user) or 'global' (single shared register)
# Default: personal (preserves existing behavior)
CASH_REGISTER_SCOPE=personal
